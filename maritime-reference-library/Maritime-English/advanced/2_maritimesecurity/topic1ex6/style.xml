<?xml version="1.0" encoding="UTF-8"?>
<style folder="res">
	<font name="LingonetArial" source="lingonetarial.swf" />
	<filter name="itemFilter" type="shadow" alpha="0" />
	
	<boolean name="checkButtonAlwaysVisible">true</boolean>
	<boolean name="noReactiveClick">true</boolean>
	
	<image name="playPageButton" x="400" y="488">play.png</image>
	<image name="checkButton" x="488" y="488">check.png</image>
	<image name="bubble" x="0" y="0">bubble.png</image>
	
	<boolean name="noReactiveClick">true</boolean>
	<boolean name="useReflectionMode">false</boolean>
	<boolean name="autoClose">false</boolean>
		
	<textfield name="correctText">
        <position x="83" y="503" />
        <size w="67" h="39" />
        <format antialiasing="better" fontFamily="Arial" color="0x1A619F" size="16" bold="true" align="center" />
        <text>{correct}%</text>
    </textfield>
	
	<textfield name="bubbleText">
		<position x="10" y="3" />
		<size w="600" h="40" />
		<format fontFamily="Arial" color="0x000000" size="14" align="center" bold="false" />
		<text>teksti</text>
	</textfield>
	
	<grid name="blockGrid">
		<dimensions rows="8" cols="1" />
		<position x="50" y="140" />
		<spacing x="0" y="55" />
	</grid>
	
	<loader name="ui">
		<image name="bg">bg.png</image>
		
		<textfield name="taskname">
			<position x="179" y="40" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="14" align="left" />
			<text><![CDATA[Ship Security Assessment / Ex 6]]></text>
		</textfield>
		
		<textfield name="unit">
			<position x="179" y="14" />
			<size w="533" h="23" />
			<format fontFamily="Arial" color="0xFFFFFF" size="20" align="left" />
			<text><![CDATA[Maritime Security]]></text>
		</textfield>
		
		<info name="info">
			<button x="160" y="488">info.png</button>
			<background x="160" y="170">infobg.jpg</background>
			<textfield>
				<position x="17" y="36" />
				<size w="369" h="150" />
				<format fontFamily="Arial" color="0x000000" size="16" />
				<text><![CDATA[Click "Play" and listen. Put the items in the order you hear them.]]></text>
			</textfield>
		</info>

		<textpoints name="score">
			<values max="12" correct="1" error="0" min="0" correctOnFirst="2" />
			<background x="82" y="494">clear.gif</background>
			<points>
				<position x="82" y="504" />
				<size w="67" h="39" />
				<format fontFamily="Arial" color="0x1A619F" size="16" bold="true" align="center" />
				<text></text>
			</points>
			<complete>
				<fx type="fade" from="0" to="1" duration="300" />
				<fx type="move" x="218" y="482" duration="500" delay="1500" />
				<fx type="scale" to="0.55" from="1" duration="500" delay="1500" />
				<ranges>
					<range min="-10000">
						<image x="230" y="209">done.gif</image>
					</range>
				</ranges>
			</complete>
		</textpoints>
	</loader>
</style>
