<?xml version="1.0" encoding="UTF-8"?>
<style folder="res/">
	<font name="LingonetArial" source="lingonetarial.swf" />
	<image name="done" x="300" y="7">clear.gif</image>
	<fx name="fadeIn" type="fade" from="0" to="1" duration="250" />
	
<image name="background">clear.gif</image>
		
	<image name="start" x="488" y="488">start.png</image>
	<image name="play" x="488" y="488">play.png</image>

	<image name="image1" x="38" y="102">pic1.png</image>
	<image name="image2" x="38" y="172">pic2.png</image>
	<image name="image3" x="38" y="242">pic3.png</image>
	<image name="image4" x="38" y="312">pic4.png</image>
	<image name="image5" x="38" y="382">pic5.png</image>
	<image name="image1done" x="281" y="312">pic1b.png</image>
	<image name="image2done" x="669" y="275">pic2b.png</image>
	<image name="image3done" x="483" y="314">pic3b.png</image>
	<image name="image4done" x="196" y="228">pic4b.png</image>
	<image name="image5done" x="184" y="311">pic5b.png</image>
	
	<textfield name="info-text">
		<position x="26000" y="29" />
		<size w="400" h="70" />
		<format fontFamily="Arial" color="0x000000" size="16" />
		<text></text>
	</textfield>
<image name="pointsbg" x="5000" y="0">clear.gif</image>
<textfield name="point-field">
<position x="5000" y="0" />
		<position x="31" y="553" />
		<size w="100" h="16" />
		<format fontFamily="Arial" color="0x000000" size="12" align="center" />
		<text></text>
	</textfield>	
	<textfield name="task-name">
		<position x="6550" y="11" />
		<size w="136" h="20" />
		<format fontFamily="Arial" color="0xFFFFFF" size="12" align="center" />
		<text></text>
	</textfield>

	<loader name="ui">
		<image name="background">bg.png</image>
		
		<textfield name="taskname">
			<position x="179" y="40" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="14" align="left" />
			<text><![CDATA[Anti-fouling / Ex 2]]></text>
		</textfield>
		
		<textfield name="unit">
			<position x="179" y="14" />
			<size w="533" h="23" />
			<format fontFamily="Arial" color="0xFFFFFF" size="20" align="left" />
			<text><![CDATA[The Marine Environment]]></text>
		</textfield>
		
		<textpoints name="score">
			<values max="10" correct="1" error="0" min="0" correctOnFirst="2" />
			<background x="82" y="494">scorebg.png</background>
			<points>
				<position x="82" y="504" />
				<size w="67" h="39" />
				<format fontFamily="Arial" color="0x1A619F" size="16" bold="true" align="center" />
				<text><![CDATA[{points} / {maxpoints}]]></text>
			</points>
			<complete>
				<fx type="fade" from="0" to="1" duration="300" />
				<fx type="move" x="218" y="482" duration="500" delay="1500" />
				<fx type="scale" to="0.55" from="1" duration="500" delay="1500" />
				<ranges>
					<range min="-10000">
						<image x="230" y="209">done.gif</image>
					</range>
				</ranges>
			</complete>
		</textpoints>
		
		<info name="info">
			<button x="160" y="488">info.png</button>
			<background x="160" y="170">infobg.jpg</background>
			<textfield>
				<position x="17" y="36" />
				<size w="369" h="150" />
				<format fontFamily="Arial" color="0x000000" size="16" />
				<text><![CDATA[Click "Start". Listen. Follow the instructions.]]></text>
			</textfield>
		</info>
	</loader>
</style>
