<?xml version="1.0" encoding="UTF-8"?>
<style folder="res">
	<font name="LingonetArial" source="lingonetarial.swf" />
	<boolean name="reactiveClick">false</boolean>

	<boolean name="autoExit">true</boolean>

	<image name="slider" x="42" y="21">k1kupla.png</image>
	<image name="playButton">play.png</image>
		
	<image name="correctTick">ok.png</image>
	
	<image name="solveButton" x="408" y="488">solve.png</image>
	<image name="checkButton" x="488" y="488">check.png</image>
	
	<grid name="items">
		<dimensions rows="10" cols="2" />
		<position x="51" y="104" />
		<spacing x="286" y="54" />
	</grid>
	
	<grid name="ticks">
		<dimensions rows="10" cols="2" />
		<position x="178" y="99" />
		<spacing x="290" y="54" />
	</grid>
	
	<loader name="ui">
		<image name="background">bg.jpg</image>

		<textfield name="unit">
			<position x="179" y="14" />
			<size w="533" h="23" />
			<format fontFamily="Arial" color="0xFFFFFF" size="20" align="left" />
			<text><![CDATA[The Weather]]></text>
		</textfield>

		<textfield name="taskname">
			<position x="179" y="40" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="14" align="left" />
			<text><![CDATA[The Weather and the Months / Ex 7]]></text>
		</textfield>
		
		<textpoints name="score">
			<values max="26" correct="1" error="0" min="0" correctOnFirst="2" />
			<background x="82" y="494">scorebg.png</background>
			<points>
				<position x="82" y="504" />
				<size w="67" h="39" />
				<format fontFamily="Arial" color="0x1A619F" size="16" bold="true" align="center" />
				<text><![CDATA[{points} / {maxpoints}]]></text>
			</points>
			<complete>
				<fx type="fade" from="0" to="1" duration="300" />
				<fx type="move" x="218" y="482" duration="500" delay="1500" />
				<fx type="scale" to="0.55" from="1" duration="500" delay="1500" />
				<ranges>
					<range min="-10000">
						<image x="230" y="209">done.gif</image>
					</range>
				</ranges>
			</complete>
		</textpoints>

		<info name="info">
			<button x="160" y="488">info.png</button>
			<background x="160" y="170">infobg.jpg</background>
			<textfield>
				<position x="17" y="36" />
				<size w="369" h="150" />
				<format fontFamily="Arial" color="0x000000" size="16" />
				<text><![CDATA[Listen to the recording and mark the right stress by moving the yellow box under the correct syllable in the last word.]]></text>
			</textfield>
		</info>
	</loader>
	
</style>