<?xml version="1.0" encoding="UTF-8"?>
<style folder="res">
	<font name="LingonetArial" source="lingonetarial.swf" />
	
	<filter name="shadow" type="shadow" alpha="0.4" />
	
	<tween name="show" duration="0.2">
		<from>
			<fade alpha="0" />
			<blur x="10" y="10" />
		</from>
		<fade alpha="1" />
		<blur x="0" y="0" />
		<ease type="sine" in="true" out="true" />
	</tween>
	
	<tween name="hide" duration="0.2">
		<fade alpha="0" />
		<blur x="10" y="10" />
		<ease type="sine" in="true" out="true" />
	</tween>
	
	<point name="attachPoint" x="0" y="0" />
	
	<image name="bbl">bbl.png</image>
	<image name="slot" x="310" y="331">slot.png</image>
	
	<image name="textBg" x="103" y="386">textbg.png</image>
	
	<image name="continueButton" x="312" y="467">continue.png</image>
	
	<textfield name="correctText">
		<position x="20" y="25" />
		<size w="472" h="50" />
		<format fontFamily="Arial" color="0x000000" size="14" align="center" />
		<text></text>
	</textfield>
	
	<textfield name="bblText">
		<position x="0" y="11" />
		<size w="20" h="40" />
		<format fontFamily="Arial" color="0x000000" size="12" align="center" />
		<text></text>
	</textfield>
	
	<grid name="bblGrid">
		<dimensions rows="1" cols="20" />
		<position x="105" y="445" />
		<spacing x="85" y="90" />
	</grid>

	<grid name="videoGrid">
		<dimensions rows="1" cols="1" />
		<position x="10" y="77" />
		<spacing x="70" y="70" />
	</grid>
	
	<videocontrol name="videoControl">
		<showControls>false</showControls>
		<showText>false</showText>
		<display x="0" y="0" w="700" h="400" />
		<controls x="0" y="0">clear.gif</controls>
		<play x="5" y="8">clear.gif</play>
		<pause>clear.gif</pause>
		<dot x="0" y="1">clear.gif</dot>
		<text x="24" y="8">clear.gif</text>
		<progressBar x="80" y="11" w="610" h="0" color="0x909090" />
	</videocontrol>
	
	
	<loader name="ui">
		<image name="background">bg.png</image>
				
		<textfield name="unit">
			<position x="179" y="14" />
			<size w="533" h="23" />
			<format fontFamily="Arial" color="0xFFFFFF" size="20" align="left" />
			<text><![CDATA[The Weather]]></text>
		</textfield>

		<textfield name="taskname">
			<position x="179" y="40" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="14" align="left" />
			<text><![CDATA[The Weather and the Ship Movements / Ex 1]]></text>
		</textfield>
		
		<textpoints name="score">
			<values max="12" correct="1" error="0" min="0" correctOnFirst="2" />
			<background x="82" y="494">scorebg.png</background>
			<points>
				<position x="82" y="504" />
				<size w="67" h="39" />
				<format fontFamily="Arial" color="0x1A619F" size="16" bold="true" align="center" />
				<text><![CDATA[{points} / {maxpoints}]]></text>
			</points>
			<complete>
				<fx type="fade" from="0" to="1" duration="300" />
				<fx type="move" x="218" y="482" duration="500" delay="1500" />
				<fx type="scale" to="0.55" from="1" duration="500" delay="1500" />
				<ranges>
					<range min="-10000">
						<image x="230" y="209">done.gif</image>
					</range>
				</ranges>
			</complete>
		</textpoints>
		
		<info name="info">
			<button x="160" y="488">info.png</button>
			<background x="160" y="170">infobg.jpg</background>
			<textfield>
				<position x="17" y="36" />
				<size w="369" h="150" />
				<format fontFamily="Arial" color="0x000000" size="16" />
				<htmlText><![CDATA[<b>Wind</b> and <b>waves</b> can make <b>the ship</b> move in six different ways. Click the sound bubbles below and move the one which best describes the movement to the empty slot.]]></htmlText>
			</textfield>
		</info>
		
	</loader>
	
</style>
