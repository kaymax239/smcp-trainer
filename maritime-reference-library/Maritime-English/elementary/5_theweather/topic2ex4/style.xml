<?xml version="1.0" encoding="UTF-8"?>
<style folder="res/">
	<font name="LingonetArial" source="lingonetarial.swf" />

	<boolean name="autoExit">false</boolean>
	<number name="maskAlpha">0.0</number>
	
	<rectangle name="clickMask" x="5" y="95" w="710" h="365" />
	
	<image name="startButton" x="580" y="488">start.png</image>
	<image name="playButton" x="580" y="488">play.png</image>
	
	<!-- Loader -->
	<loader name="ui">
		<image name="background">bg.png</image>
	
		<textfield name="unit">
			<position x="179" y="14" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="20" align="left" />
			<text><![CDATA[The Weather]]></text>
		</textfield>

		<textfield name="taskname">
			<position x="179" y="40" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="14" align="left" />
			<text><![CDATA[The Weather and the Months / Ex 4]]></text>
		</textfield>
	
		<textpoints name="score">
			<values max="6" correct="1" error="0" min="0" items="8" correctOnFirst="2" />
			<background x="82" y="494">scorebg.png</background>
			<points>
				<position x="82" y="504" />
				<size w="67" h="39" />
				<format fontFamily="Arial" color="0x1A619F" size="16" bold="true" align="center" />
				<text><![CDATA[{points} / {maxpoints}]]></text>
			</points>		
			<complete>
				<fx type="fade" from="0" to="1" duration="300" />
				<fx type="move" x="218" y="482" duration="500" delay="1500" />
				<fx type="scale" to="0.55" from="1" duration="500" delay="1500" />
				<ranges>
					<range min="-10000">
						<image x="230" y="209">done.gif</image>
					</range>
				</ranges>
			</complete>
		</textpoints>
		
		<info name="info">
			<button x="160" y="488">info.png</button>
			<background x="160" y="170">infobg.jpg</background>
			<textfield>
				<position x="17" y="36" />
				<size w="369" h="150" />
				<format fontFamily="Arial" color="0x000000" size="16" />
				<text><![CDATA[Look at the map of Australia, listen to the speaker and answer the questions.]]></text>
			</textfield>
		</info>
	</loader>	
</style>