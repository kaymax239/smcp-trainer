<?xml version="1.0" encoding="UTF-8"?>
<style folder="res">
	<font name="LingonetArial" source="lingonetarial.swf" />
	
	<tween name="show" duration="0.2">
		<from>
			<fade alpha="0" />
			<blur x="10" y="10" />
		</from>
		<fade alpha="1" />
		<blur x="0" y="0" />
		<ease type="sine" in="true" out="true" />
	</tween>
	
	<tween name="hide" duration="0.2">
		<fade alpha="0" />
		<blur x="10" y="10" />
		<ease type="sine" in="true" out="true" />
	</tween>
	
	<image name="play">play.png</image>
	
	<color name="coverColor">0xAAAAAA</color>
	
	<textfield name="text">
		<position x="179" y="40" />
		<size w="533" h="19" />
		<format fontFamily="Arial" color="0x000000" size="14" align="left" />
		<text><![CDATA[]]></text>
	</textfield>
	
	
	<loader name="ui">
		<image name="background" x="0" y="0">bg.png</image>
		
		<textfield name="unit">
			<position x="179" y="14" />
			<size w="533" h="23" />
			<format fontFamily="Arial" color="0xFFFFFF" size="20" align="left" />
			<text><![CDATA[The Weather]]></text>
		</textfield>
		
		<textfield name="taskname">
			<position x="179" y="40" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="14" align="left" />
			<text><![CDATA[The Weather and the Months / Ex 2]]></text>
		</textfield>
		
		<textpoints name="score">
			<values max="8" correct="1" error="0" min="0" correctOnFirst="2" />
			<!--<points>
				<position x="82" y="504" />
				<size w="67" h="39" />
				<format fontFamily="Arial" color="0x1A619F" size="16" bold="true" align="center" />
				<text><![CDATA[{points} / {maxpoints}]]></text>
			</points>-->
			<complete>
				<fx type="fade" from="0" to="1" duration="300" />
				<fx type="move" x="218" y="482" duration="500" delay="1500" />
				<fx type="scale" to="0.55" from="1" duration="500" delay="1500" />
				<ranges>
					<range min="-10000">
						<image x="230" y="209">done.gif</image>
					</range>
				</ranges>
			</complete>
		</textpoints>
		
		<info name="info">
			<button x="160" y="488">info.png</button>
			<background x="160" y="170">infobg.jpg</background>
			<textfield>
				<position x="17" y="36" />
				<size w="369" h="150" />
				<format fontFamily="Arial" color="0x000000" size="16" />
				<text><![CDATA[The table shows what weather to expect in Poland at different times of the year. Listen to the text by clicking on the play buttons and read the text.]]></text>
			</textfield>
		</info>
	</loader>
</style>
