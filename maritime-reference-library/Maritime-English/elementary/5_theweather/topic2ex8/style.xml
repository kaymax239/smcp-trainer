<?xml version="1.0" encoding="UTF-8"?>
<style folder="res">
	<font name="LingonetArial" source="lingonetarial.swf" />
	
	<image name="quit-button" x="714" y="455">clear.gif</image>
	<image name="complete-button" x="714" y="455">clear.gif</image>
	<image name="start-button" x="349" y="394">clear.gif</image>
	<image name="check-button" x="488" y="488">check.png</image>
	
	<filter name="shadow" type="shadow" distance="4" alpha="0.65" />
		
	<fx name="fadeIn" type="fade" from="0" to="1" duration="250" />
	<fx name="fadeOut" type="fade" from="1" to="0" duration="250" />
	
	<image name="hint1" x="0" y="0">clear.gif</image>
	<image name="hint2" x="0" y="0">clear.gif</image>
	<image name="hint3" x="0" y="0">clear.gif</image>
	<image name="hint4" x="0" y="0">clear.gif</image>
	<image name="hint5" x="0" y="0">clear.gif</image>
	<image name="hint6" x="0" y="0">clear.gif</image>
		
	<image name="text-box">textbg.png</image>
	<textformat name="gap-text" fontFamily="Arial" color="0x000000" size="16" align="center" bold="false" />
	<textformat name="gap-gap" fontFamily="Arial" color="0x000000" size="16" align="center" bold="false" />
	<textformat name="gap-correct" fontFamily="Arial" color="0x000000" size="16" align="center" bold="false" />
	<textformat name="gap-error" fontFamily="Arial" color="0xFF0000" size="16" align="center" bold="false" />
	<generic name="gap-indicator">full-line</generic>
	<point name="gap-padding" x="0" y="0" />
	
	<image name="wrong" x="250" y="200">c1wrong.jpg</image>
	<rectangle name="wrongContinue" x="80" y="105" w="93" h="19" />
	<image name="done" x="250" y="200">c1ok.jpg</image>
	<rectangle name="doneContinue" x="80" y="105" w="93" h="19" />

	<loader name="ui">
		<image name="background">bg.png</image>
		
		<textfield name="taskname">
			<position x="179" y="40" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="14" align="left" />
			<text><![CDATA[The Weather and the Months / Ex 8]]></text>
		</textfield>
		
		<textfield name="unit">
			<position x="179" y="14" />
			<size w="533" h="23" />
			<format fontFamily="Arial" color="0xFFFFFF" size="20" align="left" />
			<text><![CDATA[The Weather]]></text>
		</textfield>

		<textpoints name="score">
			<values max="12" correct="1" error="0" min="0" correctOnFirst="2" />
			<background x="82" y="494">scorebg.png</background>
			<points>
				<position x="82" y="504" />
				<size w="67" h="39" />
				<format fontFamily="Arial" color="0x1A619F" size="16" bold="true" align="center" />
				<text><![CDATA[{points} / {maxpoints}]]></text>
			</points>
			<complete>
				<fx type="fade" from="0" to="1" duration="300" />
				<fx type="move" x="218" y="482" duration="500" delay="1500" />
				<fx type="scale" to="0.55" from="1" duration="500" delay="1500" />
				<ranges>
					<range min="-10000">
						<image x="230" y="209">done.gif</image>
					</range>
				</ranges>
			</complete>
		</textpoints>

		<info name="info">
			<button x="160" y="488">info.png</button>
			<background x="160" y="170">infobg.jpg</background>
			<textfield>
				<position x="17" y="36" />
				<size w="369" h="150" />
				<format fontFamily="Arial" color="0x000000" size="16" />
				<text><![CDATA[Complete the table by forming adjectives from the nouns.]]></text>
			</textfield>
		</info>
	</loader>
</style>