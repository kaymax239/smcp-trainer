<?xml version="1.0" encoding="UTF-8"?>
<style folder="res">
	<font name="LingonetArial" source="lingonetarial.swf" />
	
	<image name="returnButton" x="0" y="0">clear.gif</image>
	
	<textfield name="textField" x="0" y="50" width="685" height="20">
		<position x="0" y="70" />
		<size w="685" h="20" />
		<format fontFamily="Arial" size="14" color="0x000000" bold="true" />
		<text></text>
	</textfield>
	
	<image name="gap1">gap1.png</image>
	<image name="gap2">gap2.png</image>
	<image name="gap3">gap3.png</image>
	<image name="gap4">gap4.png</image>
	
	<image name="gap1down">gap1down.png</image>
	<image name="gap2down">gap2down.png</image>
	<image name="gap3down">gap3down.png</image>
	<image name="gap4down">gap4down.png</image>
	
	<image name="textBackground" x="20" y="100">clear.gif</image>
	
	<boolean name="ignoreCase">false</boolean>
	
	<rectangle name="gapBounds" x="10" y="10" w="670" h="400" />
	<textformat name="gapTextFormat" fontFamily="Arial" size="14" color="0x000000" />
	<textformat name="gapFormat" fontFamily="Arial" size="14" color="0x000000" leftMargin="20" rightMargin="10" />
	<textformat name="gapCorrectFormat" fontFamily="Arial" size="14" color="0x000000" leftMargin="20" rightMargin="10" />
	<textformat name="gapWrongFormat" fontFamily="Arial" size="14" color="0x000000" leftMargin="20" rightMargin="10"/>
	
	<generic name="gapSpriteWidthCorrection" type="number">-10</generic>
	<point name="gapSpriteCorrection" x="10" y="0" />
	
	<generic name="lineSpacing" type="number">15</generic>
	
	<image name="stopPic" x="206" y="219">gaperror.png</image>
	<rectangle name="stopPicBtnRect" x="261" y="7" w="29" h="29" />
	
	<textformat name="answerFormat" fontFamily="Arial" size="14" color="0x0000FF" bold="true" />
	
	<image name="toolbar" x="112" y="405">toolbar.png</image>
	<textfield name="toolbarTextField">'
		<position x="142" y="13" />
		<size w="344" h="22" />
		<format fontFamily="Arial" size="16" xolor="0x000000" bold="false" />
		<text></text>
	</textfield>
	
	<image name="toolbarListenButton" x="160" y="45">listen.png</image>
	<image name="spellButton" x="240" y="45">spell.png</image>
	<image name="skipButton" x="320" y="45">skip.png</image>
	<image name="applyButton" x="400" y="45">apply.png</image>
	
	<loader name="ui">
		<image name="background" x="0" y="0">bg.jpg</image>
		
		<textfield name="unit">
			<position x="179" y="14" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="20" align="left" />
			<text><![CDATA[Maritime Security]]></text>
		</textfield>
		
		<textfield name="taskname">
			<position x="179" y="40" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="14" align="left" />
			<text><![CDATA[ Stowaways / Ex 1]]></text>
		</textfield>
		
		<textpoints name="score">
			<values max="14" correct="1" error="0" min="0" correctOnFirst="2" />
			<background x="69" y="494">scorebg2.png</background>
			<points>
				<position x="69" y="504" />
				<size w="86" h="39" />
				<format fontFamily="Arial" color="0x1A619F" size="16" bold="true" align="center" />
				<text><![CDATA[{points} / {maxpoints}]]></text>
			</points>

			<complete>
				<fx type="fade" from="0" to="1" duration="300" />
				<fx type="move" x="218" y="482" duration="500" delay="1500" />
				<fx type="scale" to="0.55" from="1" duration="500" delay="1500" />
				<ranges>
					<range min="-10000">
						<image x="230" y="209">done.gif</image>
					</range>
				</ranges>
			</complete>
		</textpoints>
		
		<info name="info">
			<button x="160" y="488">info.png</button>
			<background x="160" y="170">infobg.jpg</background>
			<textfield>
				<position x="17" y="36" />
				<size w="369" h="150" />
				<format fontFamily="Arial" color="0x000000" size="16" />
				<text><![CDATA[Complete the sentences. For help click on "Listen" or "Spell".]]></text>
			</textfield>
		</info>
	</loader>
</style>
