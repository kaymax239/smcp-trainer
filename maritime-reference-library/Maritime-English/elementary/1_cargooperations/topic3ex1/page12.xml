<?xml version="1.0" encoding="UTF-8"?>
<root>
  <header />
  <body>
    <scene sceneType="PointingNavigating">
      <name>page12</name>
      <background>page12/pumping plant.jpg</background>
      <title>Lingowalk Oil Terminal</title>
      <events>
        <onEnterScene>
          <actions type="list" randomize="false" />
        </onEnterScene>
        <onMainQueueStart>
          <actions type="list" randomize="false">
            <action actionType="hotspot">
              <hotspots type="list">
                <points type="list">
                  <point x="number:123" y="number:241" />
                  <point x="number:123" y="number:251" />
                  <point x="number:131" y="number:260" />
                  <point x="number:130" y="number:271" />
                  <point x="number:146" y="number:271" />
                  <point x="number:146" y="number:248" />
                  <point x="number:135" y="number:240" />
                  <point x="number:127" y="number:236" />
                </points>
              </hotspots>
              <name>switch board</name>
              <events>
                <onPrompt>
                  <actions type="list" randomize="false">
                    <action actionType="audio">
                      <file>page12/pw038.mp3</file>
                      <text><![CDATA[On a pumping plant the most important structures are the pumps, the valves and the emergency shutdown. In the photo the emergency shutdown is on the switchboard on the left, behind the red box. Please click on the switchboard. ]]></text>
                      <repeatsBeforeText type="number">1</repeatsBeforeText>
                      <requireNext type="boolean">false</requireNext>
                    </action>
                  </actions>
                </onPrompt>
                <onCorrect>
                  <actions type="list" randomize="false">
                    <action actionType="loadScene">
                      <file>page12b.xml</file>
                    </action>
                  </actions>
                </onCorrect>
                <onError>
                  <actions type="list" randomize="false">
                    <action actionType="audio">
                      <file>page12/pw040.mp3</file>
                      <text><![CDATA[No, the switchboard is behind the red box on the left. Try again.]]></text>
                      <repeatsBeforeText type="number">1</repeatsBeforeText>
                      <requireNext type="boolean">false</requireNext>
                    </action>
                  </actions>
                </onError>
              </events>
            </action>
          </actions>
        </onMainQueueStart>
        <onMainQueueEmpty>
          <actions type="list" randomize="false" />
        </onMainQueueEmpty>
        <onOptionalQueue>
          <actions type="list" randomize="false" />
        </onOptionalQueue>
        <onForwardButton>
          <actions type="list" randomize="false" />
        </onForwardButton>
        <onBackwardButton>
          <actions type="list" randomize="false" />
        </onBackwardButton>
        <onLeftButton>
          <actions type="list" randomize="false" />
        </onLeftButton>
        <onRightButton>
          <actions type="list" randomize="false" />
        </onRightButton>
        <onExitScene>
          <actions type="list" randomize="false" />
        </onExitScene>
      </events>
    </scene>
  </body>
</root>