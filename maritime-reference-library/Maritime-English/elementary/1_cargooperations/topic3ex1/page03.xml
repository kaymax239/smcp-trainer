              <name>pipeline</name>
              <events>
                <onPrompt>
                  <actions type="list" randomize="false">
                    <action actionType="audio">
                      <file>page03/pw008.mp3</file>
                      <text><![CDATA[Tankers carry liquid bulk cargo in cargo tanks. There are different kinds of tankers: oil tankers, chemical tankers and gas tankers. Oil tankers are crude oil tankers, product tankers or combination tankers. A product tanker carries various grades of products. A tanker usually has pipelines on the deck.

Can you see the pipelines on the deck of the tanker? Please click on them.  ]]></text>
                      <repeatsBeforeText type="number">1</repeatsBeforeText>
                      <requireNext type="boolean">false</requireNext>
                    </action>
                  </actions>
                </onPrompt>
                <onCorrect>
                  <actions type="list" randomize="false">
                    <action actionType="loadScene">
                      <file>page04.xml</file>
                    </action>
                  </actions>
                </onCorrect>
                <onError>
                  <actions type="list" randomize="false">
                    <action actionType="audio">
                      <file>page03/pw010.mp3</file>
                      <text><![CDATA[No, I’m sorry, they are not pipelines. Please try again.]]></text>
                      <repeatsBeforeText type="number">1</repeatsBeforeText>
                      <requireNext type="boolean">false</requireNext>
                    </action>
                  </actions>
                </onError>
              </events>
            </action>
          </actions>
        </onMainQueueStart>
        <onMainQueueEmpty>
          <actions type="list" randomize="false" />
        </onMainQueueEmpty>
        <onOptionalQueue>
          <actions type="list" randomize="false" />
