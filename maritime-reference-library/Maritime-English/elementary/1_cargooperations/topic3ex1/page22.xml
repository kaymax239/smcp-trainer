                      <file>page22/pw062.mp3</file>
                      <text><![CDATA[Behind the water pipe and the fire extinguisher you can see a part of a water and foam monitor. Please, click on it.]]></text>
                      <repeatsBeforeText type="number">1</repeatsBeforeText>
                      <requireNext type="boolean">false</requireNext>
                    </action>
                  </actions>
                </onPrompt>
                <onCorrect>
                  <actions type="list" randomize="false">
                    <action actionType="audio">
                      <file>page22/pw063.mp3</file>
                      <text><![CDATA[Yes, you got it right.]]></text>
                      <repeatsBeforeText type="number">1</repeatsBeforeText>
                      <requireNext type="boolean">false</requireNext>
