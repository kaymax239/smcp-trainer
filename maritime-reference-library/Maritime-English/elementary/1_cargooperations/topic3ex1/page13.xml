<?xml version="1.0" encoding="UTF-8"?>
<root>
  <header />
  <body>
    <scene sceneType="PointingNavigating">
      <name>page13</name>
      <background>page13/emergency stop.jpg</background>
      <title>Lingowalk Oil Terminal</title>
      <events>
        <onEnterScene>
          <actions type="list" randomize="false" />
        </onEnterScene>
        <onMainQueueStart>
          <actions type="list" randomize="false">
            <action actionType="hotspot">
              <hotspots type="list">
                <points type="list">
                  <point x="number:246" y="number:326" />
                  <point x="number:244" y="number:340" />
                  <point x="number:262" y="number:341" />
                  <point x="number:264" y="number:324" />
                  <point x="number:250" y="number:323" />
                </points>
              </hotspots>
              <name>emergency stop button</name>
              <events>
                <onPrompt>
                  <actions type="list" randomize="false">
                    <action actionType="audio">
                      <file>page13/pw042.mp3</file>
                      <text><![CDATA[Can you show me the emergency stop button? Please click on it.]]></text>
                      <repeatsBeforeText type="number">1</repeatsBeforeText>
                      <requireNext type="boolean">false</requireNext>
                    </action>
                  </actions>
                </onPrompt>
                <onCorrect>
                  <actions type="list" randomize="false">
                    <action actionType="loadScene">
                      <file>page13b.xml</file>
                    </action>
                  </actions>
                </onCorrect>
                <onError>
                  <actions type="list" randomize="false">
                    <action actionType="audio">
                      <file>page13/pw044b.mp3</file>
                      <text><![CDATA[Try again. It’s the one on the left hand side.]]></text>
                      <repeatsBeforeText type="number">1</repeatsBeforeText>
                      <requireNext type="boolean">false</requireNext>
                    </action>
                  </actions>
                </onError>
              </events>
            </action>
          </actions>
        </onMainQueueStart>
        <onMainQueueEmpty>
          <actions type="list" randomize="false" />
        </onMainQueueEmpty>
        <onOptionalQueue>
          <actions type="list" randomize="false" />
        </onOptionalQueue>
        <onForwardButton>
          <actions type="list" randomize="false" />
        </onForwardButton>
        <onBackwardButton>
          <actions type="list" randomize="false" />
        </onBackwardButton>
        <onLeftButton>
          <actions type="list" randomize="false" />
        </onLeftButton>
        <onRightButton>
          <actions type="list" randomize="false" />
        </onRightButton>
        <onExitScene>
          <actions type="list" randomize="false" />
        </onExitScene>
      </events>
    </scene>
  </body>
</root>