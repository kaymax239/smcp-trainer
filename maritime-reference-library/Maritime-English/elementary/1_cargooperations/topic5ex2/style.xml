<?xml version="1.0" encoding="UTF-8"?>
<style folder="res/">
	<font name="LingonetArial" source="lingonetarial.swf" />
	<fx name="fadeIn" type="fade" from="0" to="1" duration="250" />
	<fx name="fadeOut" type="fade" from="1" to="0" duration="250" />
	<filter name="shadow" type="shadow" alpha="0.4" />
		
	<image name="bbl">bbl.png</image>
	<image name="slot">slot.png</image>
		
	<grid name="bblGrid">
		<dimensions rows="4" cols="1" />
		<position x="27" y="205" />
		<spacing x="0" y="40" />
	</grid>
	
	<grid name="slotGrid">
		<dimensions rows="2" cols="2" />
		<position x="175" y="130" />
		<spacing x="148" y="138" />
	</grid>
	
	<textfield name="gapField">
		<position x="2" y="1" />
		<size w="136" h="25" />
		<format fontFamily="Arial" color="0x990000" size="12" bold="false" align="center" />
		<text></text>
	</textfield>
	
	<textfield name="slotText">
		<position x="0" y="3" />
		<size w="120" h="24" />
		<format fontFamily="Arial" color="0x000000" size="12" align="center" bold="true" />
		<text></text>
	</textfield>
	
	<textfield name="bblText">
		<position x="0" y="5" />
		<size w="62" h="21" />
		<format fontFamily="Arial" color="0x000000" size="12" align="center" />
		<text></text>
	</textfield>
	
	<image name="gapBackground" x="190" y="209">textbg.png</image>
	
	<point name="gapPadding" x="-35" y="-40" />
	<textformat name="gapFormat" fontFamily="Arial" color="0x000000" size="14" bold="false" align="center" />
	<textformat name="gapGapFormat" fontFamily="Arial" color="0x000000" size="14" bold="false" align="center" />
	<textformat name="gapCorrectFormat" fontFamily="Arial" color="0x00AA00" size="14" bold="false" align="center" />
	<textformat name="gapErrorFormat" fontFamily="Arial" color="0xFF0000" size="14" bold="false" align="center" />
	<generic name="gapIndicator">full-line</generic>
	
	<generic name="showMasks">false</generic>
	
	<rectangle name="playRect" x="21" y="103" w="94" h="21" />
	<rectangle name="checkRect" x="198" y="103" w="94" h="21" />
	<rectangle name="backRect" x="379" y="103" w="94" h="21" />
	
	<loader name="ui">
		<image name="background" x="0" y="0">bg.png</image>
		
		<textfield name="taskname">
			<position x="179" y="40" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="14" align="left" />
			<text><![CDATA[Ro-Ro Vessels / Ex 2]]></text>
		</textfield>
		
		<textfield name="unit">
			<position x="179" y="14" />
			<size w="533" h="23" />
			<format fontFamily="Arial" color="0xFFFFFF" size="20" align="left" />
			<text><![CDATA[Cargo Operations]]></text>
		</textfield>
		
		<textpoints name="score">
			<values max="16" correct="1" error="0" min="0" correctOnFirst="2" />
			<background x="82" y="494">scorebg.png</background>
			<points>
				<position x="82" y="504" />
				<size w="67" h="39" />
				<format fontFamily="Arial" color="0x1A619F" size="16" bold="true" align="center" />
				<text><![CDATA[{points} / {maxpoints}]]></text>
			</points>
			<complete>
				<fx type="fade" from="0" to="1" duration="300" />
				<fx type="move" x="218" y="482" duration="500" delay="1500" />
				<fx type="scale" to="0.55" from="1" duration="500" delay="1500" />
				<ranges>
					<range min="-10000">
						<image x="230" y="209">done.gif</image>
					</range>
				</ranges>
			</complete>
		</textpoints>
		
		<info name="info">
			<button x="160" y="488">info.png</button>
			<background x="160" y="170">infobg.jpg</background>
			<textfield>
				<position x="17" y="36" />
				<size w="369" h="150" />
				<format fontFamily="Arial" color="0x000000" size="16" />
				<text><![CDATA[Click on the yellow bars and listen. Drag each bar onto the picture it describes and write the description you heard on the line.]]></text>
			</textfield>
		</info>
	</loader>
	
</style>
