<?xml version="1.0" encoding="UTF-8"?>
<style folder="res">
	<font name="LingonetArial" source="lingonetarial.swf" />
	<filter name="itemFilter" type="shadow" alpha="0.2" />

	<!-- Check button -->
	<image name="checkButton" x="488" y="488">check.png</image>
	
	<!-- Grid positions all items -->
	<grid name="itemGrid">
		<dimensions rows="6" cols="1" />
		<position x="100" y="150" />
		<spacing x="0" y="50" />
	</grid>
	
	<!-- Play button, created at -width, -height, relative to grid item origo -->
	<image name="playButton" y="3">play.png</image>
	
	<!-- Enabled and disabled tickmarks -->
	<image name="tickDisabled" y="-2">tick0.png</image>
	<image name="tickEnabled" y="-2">tick1.png</image>
	<boolean name="lockOnCorrect">true</boolean>
	
	<!-- CorrectImage, relative to item -->
	<image name="correct" x="448" y="23">oksign.png</image>
	
	<!-- relative to itemGrid point -->
	<textfield name="text">
		<position x="10" y="3" />
		<size w="450" h="20" />
		<format fontFamily="Arial" color="0x000000" size="14" align="left" bold="false" />
		<text>teksti</text>
	</textfield>

	<!-- relative to itemGrid point -->
	<grid name="tickGrid">
		<dimensions rows="1" cols="3" />
		<position x="440" y="0" />
		<spacing x="48" y="0" />
	</grid>
	
	<loader name="ui">
		<image name="bg">bg.png</image>

		<textfield name="taskname">
			<position x="179" y="40" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="14" align="left" />
			<text><![CDATA[Cargo Space in Bulk Terminals / Ex 2]]></text>
		</textfield>
		
		<textfield name="unit">
			<position x="179" y="14" />
			<size w="533" h="23" />
			<format fontFamily="Arial" color="0xFFFFFF" size="20" align="left" />
			<text><![CDATA[Cargo Operations]]></text>
		</textfield>

		<textpoints name="score">
			<values max="22" correct="1" error="0" min="0" correctOnFirst="2" />
			<background x="82" y="494">scorebg.png</background>
			<points>
				<position x="82" y="504" />
				<size w="67" h="39" />
				<format fontFamily="Arial" color="0x1A619F" size="16" bold="true" align="center" />
				<text><![CDATA[{points} / {maxpoints}]]></text>
			</points>
			<complete>
				<fx type="fade" from="0" to="1" duration="300" />
				<fx type="move" x="218" y="482" duration="500" delay="1500" />
				<fx type="scale" to="0.55" from="1" duration="500" delay="1500" />
				<ranges>
					<range min="-10000">
						<image x="230" y="209">done.gif</image>
					</range>
				</ranges>
			</complete>
		</textpoints>

		<info name="info">
			<button x="160" y="488">info.png</button>
			<background x="160" y="170">infobg.jpg</background>
			<textfield>
				<position x="17" y="36" />
				<size w="369" h="150" />
				<format fontFamily="Arial" color="0x000000" size="16" />
				<text><![CDATA[Listen to the sentence and tick the right pronunciation of the -ed ending of the word in bold.]]></text>
			</textfield>
		</info>
	</loader>
</style>