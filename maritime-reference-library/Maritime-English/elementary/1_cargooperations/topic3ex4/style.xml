<?xml version="1.0" encoding="UTF-8"?>
<style folder="res/">
	<font name="LingonetArial" source="lingonetarial.swf" />
	
	<tween name="show" duration="0.2">
		<from>
			<scale x="0" y="0" />
			<fade alpha="0" />
			<blur x="10" y="10" />
		</from>
		<fade alpha="1" />
		<scale x="1" y="1" />
		<blur x="0" y="0" />
		<ease type="sine" in="true" out="true" />
	</tween>
	
	<tween name="showHint" duration="0.5">
		<from>
			<fade alpha="0" />
			<blur x="10" y="10" />
			<move y="517" />
		</from>
		<fade alpha="1" />
		<blur x="0" y="0" />
		<move y="465" />
		<ease type="sine" in="true" out="true" />
	</tween>
	
	<tween name="hideHint" duration="0.5">
		<fade alpha="0" />
		<blur x="10" y="10" />
		<move y="413" />
		<ease type="sine" in="true" out="true" />
	</tween>
	
	<tween name="hide" duration="0.2">
		<fade alpha="0" />
		<scale x="0" y="0" />
		<blur x="10" y="10" />
		<ease type="sine" in="true" out="true" />
	</tween>
	
	<image name="playButton" x="53" y="235">play.png</image>
	<image name="hintButton" x="333" y="308">hint.png</image>
	<image name="continueButton" x="318" y="350">continue.png</image>
	
	<textfield name="hintField">
		<position x="120" y="370" />
		<size w="400" h="100" />
		<verticalAlign>center</verticalAlign>
		<format fontFamily="Arial" verticalAlign="center" color="0x000000" size="14" align="center" />
	</textfield>
	
	<rectangle name="gapBounds" x="128" y="234" w="644" h="48" />
	<textformat name="gapFormat" fontFamily="Arial" color="0x000000" size="14" align="center" />
	<textformat name="gapWrongFormat" fontFamily="Arial" color="0xFF0000" size="14" align="center" />
	<textformat name="gapTextFormat" fontFamily="Arial" color="0x000000" size="14" align="center" />
	<textformat name="gapCorrectFormat" fontFamily="Arial" color="0x000000" size="14" align="center" />
	
	<loader name="ui">
		<image name="background" x="0" y="0">bg.jpg</image>
		
		<textfield name="taskname">
			<position x="179" y="40" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="14" align="left" />
			<text><![CDATA[Liquid Cargo Operations / Ex 4]]></text>
		</textfield>
		
		<textfield name="unit">
			<position x="179" y="14" />
			<size w="533" h="23" />
			<format fontFamily="Arial" color="0xFFFFFF" size="20" align="left" />
			<text><![CDATA[Cargo Operations]]></text>
		</textfield>

		<textpoints name="score">
			<values max="24" correct="1" error="0" min="0" correctOnFirst="2" />
			<background x="82" y="494">scorebg.png</background>
			<points>
				<position x="82" y="504" />
				<size w="67" h="39" />
				<format fontFamily="Arial" color="0x1A619F" size="16" bold="true" align="center" />
				<text><![CDATA[{points} / {maxpoints}]]></text>
			</points>
			<complete>
				<fx type="fade" from="0" to="1" duration="300" />
				<fx type="move" x="218" y="482" duration="500" delay="1500" />
				<fx type="scale" to="0.55" from="1" duration="500" delay="1500" />
				<ranges>
					<range min="-10000">
						<image x="230" y="209">done.gif</image>
					</range>
				</ranges>
			</complete>
		</textpoints>
		
		<info name="info">
			<button x="160" y="488">info.png</button>
			<background x="160" y="170">infobg.jpg</background>
			<textfield>
				<position x="17" y="36" />
				<size w="369" h="150" />
				<format fontFamily="Arial" color="0x000000" size="16" />
				<text><![CDATA[Listen and fill in the verb in the correct form and tense. Press Enter to check your answer.]]></text>
			</textfield>
		</info>
	
	</loader>
</style>
