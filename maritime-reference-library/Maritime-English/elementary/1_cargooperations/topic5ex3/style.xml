<?xml version="1.0" encoding="UTF-8"?>
<style folder="res">

	<font name="LingonetArial" source="lingonetarial.swf" />
	<fx     name="fadeOut"             type="fade" from="1" to="0" duration="250" />
	<fx     name="fadeIn"              type="fade" from="0" to="1" duration="250" />
	<filter name="shadow"              type="shadow" alpha="0.25" />
	
	<integer name="targetTolerance">32</integer>
	<boolean name="freeOrder">true</boolean>
	<boolean name="hideBubbleOnCorrect">true</boolean>
	<boolean name="replaceSlotText">true</boolean>

	<image name="bg1" x="0" y="0">clear.gif</image>
	
	<image name="slot">slot.png</image>
	<image name="bubble">bbl.png</image>
	
	<textfield name="bubbleText">                  <!-- Text style of a bubble -->
		<position x="0" y="1" />
		<size w="140" h="24" />
		<format fontFamily="Arial" color="0x000000" size="16" align="center" bold="false" />
		<text></text>
	</textfield>
	
	<textfield name="targetText">                  <!-- Text style of a slot -->
		<position x="0" y="1" />
		<size w="140" h="24" />
		<format fontFamily="Arial" color="0x000000" size="16" align="center" bold="false" />
		<text></text>
	</textfield>

	<grid name="bubbleGrid">                     <!-- Bubble positions -->
		<points>
			<point x="130" y="360" />
			<point x="280" y="360" />
			<point x="430" y="360" />
			<point x="203" y="390" />
			<point x="353" y="390" />
		</points>
	</grid>
	
	<point name="bubbleGridOverflowOffset" x="-26" y="26" />
	
	<loader name="ui">
		<image name="background">bg.png</image>

		<textfield name="taskname">
			<position x="179" y="40" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="14" align="left" />
			<text><![CDATA[Ro-Ro Vessels / Ex 3]]></text>
		</textfield>
		
		<textfield name="unit">
			<position x="179" y="14" />
			<size w="533" h="23" />
			<format fontFamily="Arial" color="0xFFFFFF" size="20" align="left" />
			<text><![CDATA[Cargo Operations]]></text>
		</textfield>
		
		<textpoints name="score">
			<values max="10" correct="1" error="0" min="0" correctOnFirst="2" />
			<background x="82" y="494">scorebg.png</background>
			<points>
				<position x="82" y="504" />
				<size w="67" h="39" />
				<format fontFamily="Arial" color="0x1A619F" size="16" bold="true" align="center" />
				<text><![CDATA[{points} / {maxpoints}]]></text>
			</points>
			<complete>
				<fx type="fade" from="0" to="1" duration="300" />
				<fx type="move" x="218" y="482" duration="500" delay="1500" />
				<fx type="scale" to="0.55" from="1" duration="500" delay="1500" />
				<ranges>
					<range min="-10000">
						<image x="230" y="209">done.gif</image>
					</range>
				</ranges>
			</complete>
		</textpoints>
		
		<info name="info">
			<button x="160" y="488">info.png</button>
			<background x="160" y="170">infobg.jpg</background>
			<textfield>
				<position x="17" y="36" />
				<size w="369" h="150" />
				<format fontFamily="Arial" color="0x000000" size="16" />
				<text><![CDATA[You will often need to find out different information when loading. 
Use proper SMCP questions.
Drag the missing word(s) to the spot where it belongs and complete an SMCP sentence. 
When the question is correct you will hear an answer.]]></text>
			</textfield>
		</info>
	</loader>
</style>

