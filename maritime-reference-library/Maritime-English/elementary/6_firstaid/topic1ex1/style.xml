<?xml version="1.0" encoding="UTF-8"?>
<style folder="res">
	<font name="LingonetArial" source="lingonetarial.swf" />
		
	<image name="true" x="11" y="40">true_up.png</image>
	<image name="trueCorrect">true_down.png</image>
	<image name="false" x="283" y="40">false_up.png</image>
	<image name="falseCorrect">false_down.png</image>
	
	<image name="playBtn" x="252" y="78">play.png</image>
	
	<image name="itemBg">itembg.png</image>
	
	<grid name="itemPositions">
		<dimensions rows="10" cols="2" />
		<position x="26" y="92" />
		<spacing x="340" y="127" />
	</grid>
	
	<textfield name="textField">
		<position x="61" y="15" />
		<size w="210" h="90" />
		<format fontFamily="Arial" color="0x000000" size="15" align="left" leading="4"/>
		<text></text>
	</textfield>
	
	<textfield name="buttonTexts">
		<position x="0" y="0" />
		<size w="150" h="30" />
		<format fontFamily="Arial" color="0x000000" size="20" bold="true" align="left" />
		<text></text>
	</textfield>
	
	<loader name="ui">
		<image name="background">bg.jpg</image>
		
		<textfield name="unit">
			<position x="179" y="14" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="20" align="left" />
			<text><![CDATA[First Aid]]></text>
		</textfield>
		
		<textfield name="taskname">
			<position x="179" y="40" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="14" align="left" />
			<text><![CDATA[First Aid / Ex 1]]></text>
		</textfield>
		
		<info name="info">
			<button x="160" y="488">info.png</button>
			<background x="160" y="170">infobg.jpg</background>
			<textfield>
				<position x="17" y="36" />
				<size w="369" h="150" />
				<format fontFamily="Arial" color="0x000000" size="16" />
				<text><![CDATA[Answer TRUE/FALSE to the following questions.]]></text>
			</textfield>
		</info>
				
		<textpoints name="score">
			<values max="16" correct="1" error="0" min="0" correctOnFirst="2" />
			<background x="82" y="494">scorebg.png</background>
			<points>
				<position x="82" y="504" />
				<size w="67" h="39" />
				<format fontFamily="Arial" color="0x1A619F" size="16" bold="true" align="center" />
				<text><![CDATA[{points} / {maxpoints}]]></text>
			</points>
			<complete>
				<fx type="fade" from="0" to="1" duration="300" />
				<fx type="move" x="218" y="482" duration="500" delay="1500" />
				<fx type="scale" to="0.55" from="1" duration="500" delay="1500" />
				<ranges>
					<range min="-10000">
						<image x="230" y="209">done.gif</image>
					</range>
				</ranges>
			</complete>
		</textpoints>
	</loader>
	
</style>
