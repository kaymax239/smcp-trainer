<?xml version="1.0" encoding="UTF-8"?>
<style folder="res">
	<fx name="fadeOut" type="fade" from="1" to="0" duration="250" />
	<fx name="fadeIn" type="fade" from="0" to="1" duration="250" />
	<font name="LingonetArial" source="lingonetarial.swf" />
	<generic name="maskAlpha">0</generic>
	
	<image name="controlBar" x="0" y="0">clear.gif</image>
	<rectangle name="hint1" x="248" y="488" w="46" h="45" />
	<rectangle name="hint2" x="298" y="488" w="46" h="45" />
	<rectangle name="hint3" x="348" y="488" w="46" h="45" />
	<rectangle name="hint4" x="398" y="488" w="46" h="45" />
	
	<image name="progress1">progress1.gif</image>
	<image name="progress2">progress2.gif</image>
	<image name="progress3">progress3.gif</image>
	<point name="progress" x="11" y="392" />
	<generic name="progressWidth" type="Number">75</generic>
	
	<rectangle name="checkButton" x="488" y="488" w="46" h="45" />
	
	<image name="arrow">a1xright.gif</image>
	<size name="boxPadding" w="8" h="8" />
	
	<textfield name="hintField" >
		<position x="21" y="428" />
		<size w="230" h="40" />
		<format fontFamily="Arial" color="0x000000" size="14" align="left" />
		<text></text>
	</textfield>
	
	<rectangle name="gapBounds" x="0" y="0" w="180" h="180" />
	
	<textformat name="gapTextFormat" fontFamily="Arial" color="0x000000" size="16" align="center" bold="false" />
	<textformat name="gapFormat" fontFamily="Arial" color="0x000000" size="16" align="center" bold="false" />
	<textformat name="gapCorrectFormat" fontFamily="Arial" color="0x000000" size="16" align="center" bold="false" />
	<textformat name="gapWrongFormat" fontFamily="Arial" color="0xFF0000" size="16" align="center" bold="false" />
	
	<loader name="ui">
		<image name="background" x="0" y="0">bg.png</image>
		
		<textfield name="taskname">
			<position x="179" y="40" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="14" align="left" />
			<text><![CDATA[The Navigation Bridge / Ex 4]]></text>
		</textfield>
		
		<textfield name="unit">
			<position x="179" y="14" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="20" align="left" />
			<text><![CDATA[The Navigation Bridge]]></text>
		</textfield>
		
		<textpoints name="score">
			<values max="12" correct="1" error="0" min="0" items="8" correctOnFirst="2" />
			<background x="82" y="494">scorebg.png</background>
			<points>
				<position x="82" y="504" />
				<size w="67" h="39" />
				<format fontFamily="Arial" color="0x1A619F" size="16" bold="true" align="center" />
				<text><![CDATA[{points} / {maxpoints}]]></text>
			</points>
			
			<complete>
				<fx type="fade" from="0" to="1" duration="300" />
				<fx type="move" x="475" y="482" duration="500" delay="1500" />
				<fx type="scale" to="0.55" from="1" duration="500" delay="1500" />
				<ranges>
					<range min="-10000">
						<image x="230" y="209">done.gif</image>
					</range>
				</ranges>
			</complete>

		</textpoints>
		
		<info name="info">
			<button x="160" y="488">info.png</button>
			<background x="160" y="170">infobg.jpg</background>
			<textfield>
				<position x="17" y="36" />
				<size w="369" h="150" />
				<format fontFamily="Arial" color="0x000000" size="16" />
				<text><![CDATA[Fill in the missing words. If you need help, you can get clues worth 1-4 points.]]></text>
			</textfield>
		</info>
	</loader>
</style>
