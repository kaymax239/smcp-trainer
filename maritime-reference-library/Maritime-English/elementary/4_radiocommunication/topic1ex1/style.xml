<?xml version="1.0" encoding="UTF-8"?>
<style folder="res">
	<font name="LingonetArial" source="lingonetarial.swf" />
	<fx name="fadeOut" type="fade" from="1" to="0" duration="250" />
	<fx name="fadeIn" type="fade" from="0" to="1" duration="250" />
	<image name="done" x="385" y="160">clear.gif</image>
	
	<integer name="blockWidthCorrection">15</integer>
	
	<image name="textBg" x="20" y="380">clear.gif</image>
	<point name="blockPos" x="0" y="30" />
	<rectangle name="blockSize" x="0" y="0" w="164" h="0" />
	<image name="block1">bbl1.png</image>
	<image name="block2">bbl2.png</image>
	<image name="block3">bbl3.png</image>
	<image name="fblock1">bbl1lock.png</image>
	<image name="fblock2">bbl2lock.png</image>
	<image name="fblock3">bbl3lock.png</image>
	<textfield name="blockField">
		<position x="-1" y="8" />
		<size w="250" h="28" />
		<format fontFamily="Arial" size="12" align="center" />
	</textfield>
	<image name="checkButton" x="488" y="488">check.png</image>

	<generic name="delayBetweenItems">3000</generic>
	
	
	<loader name="ui">
		<image name="background" x="0" y="0">bg.png</image>
		
		<textfield name="unit">
			<position x="179" y="14" />
			<size w="533" h="23" />
			<format fontFamily="Arial" color="0xFFFFFF" size="20" align="left" />
			<text><![CDATA[Radio Communications]]></text>
		</textfield>
		
		<textfield name="taskname">
			<position x="179" y="40" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="14" align="left" />
			<text><![CDATA[Communication Exchange / Ex 1]]></text>
		</textfield>
		
		<textpoints name="score">
			<values max="8" correct="1" error="0" min="0" correctOnFirst="2" />
			<background x="82" y="494">scorebg.png</background>
			<points>
				<position x="82" y="504" />
				<size w="67" h="39" />
				<format fontFamily="Arial" color="0x1A619F" size="16" bold="true" align="center" />
				<text><![CDATA[{points} / {maxpoints}]]></text>
			</points>
			<complete>
				<fx type="fade" from="0" to="1" duration="300" />
				<fx type="move" x="218" y="482" duration="500" delay="1500" />
				<fx type="scale" to="0.55" from="1" duration="500" delay="1500" />
				<ranges>
					<range min="-10000">
						<image x="230" y="209">done.gif</image>
					</range>
				</ranges>
			</complete>
		</textpoints>
		
		<info name="info">
			<button x="160" y="488">info.png</button>
			<background x="160" y="170">infobg.jpg</background>
			<textfield>
				<position x="17" y="36" />
				<size w="369" h="150" />
				<format fontFamily="Arial" color="0x000000" size="16" />
				<text><![CDATA[Form a sentence or a phrase by putting the words in the boxes in the right order.]]></text>
			</textfield>
		</info>
	</loader>
	
	
	<image name="pointsbg" x="871" y="27">clear.gif</image>
	<textfield name="point-field">
		<position x="8260" y="35" />
		<size w="130" h="122" />
		<format fontFamily="Arial" color="0x000000" size="20" align="center" leading="-19"/>
		<text><![CDATA[{0}
            {1}]]></text>
	</textfield>	
	<textfield name="info-text">
		<position x="0" y="0" />
		<size w="0" h="0" />
		<format fontFamily="Arial" color="0x000000" size="16" />
		<text></text>
	</textfield>
	<textfield name="task-name">
		<position x="3600" y="88" />
		<size w="273" h="27" />
		<format fontFamily="Arial" color="0xFFFFFF" size="16" align="center" />
		<text></text>
	</textfield>
	
	<image name="popStar" x="0" y="0">clear.gif</image>
	<image name="background">clear.gif</image>
	
	<image name="info" x="8700" y="112">clear.gif</image>
	<image name="infobg" x="2740" y="107">clear.gif</image>
	<generic name="maskAlpha" type="Number">0</generic>
	<textfield name="info-text">
		<position x="10" y="10" />
		<size w="580" h="102" />
		<format fontFamily="Arial" color="0x000000" size="16" />
		<text><![CDATA[]]></text>
	</textfield>
	<rectangle name="infoContinueButton" x="0" y="0" w="638" h="122" />
</style>
