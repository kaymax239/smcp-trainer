					<part audio="me52019.mp3" />
					<part audio="me52020.mp3" />
					<part audio="me52021.mp3" />
				</list:parts>
			</item>
			<item audio="me52033.mp3">
				<text>If you observe garbage disposed of in the sea within twelve nautical miles from the land you can report the pollution to the local port.</text>
				<list:parts>
					<part audio="me52023.mp3" />
					<part audio="me52024.mp3" />
					<part audio="me52025.mp3" />
					<part audio="me52026.mp3" />
					<part audio="me52027.mp3" />
