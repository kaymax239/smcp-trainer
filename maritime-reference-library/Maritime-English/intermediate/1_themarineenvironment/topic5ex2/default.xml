				</list:parts>
			</item>
			<item audio="me52022.mp3">
				<text>If you witness any discharge from a ship involving washings of chemical or dry cargoes the pollution activity should be reported.</text>
				<list:parts>
					<part audio="me52012.mp3" />
					<part audio="me52013.mp3" />
					<part audio="me52014.mp3" />
					<part audio="me52015.mp3" />
