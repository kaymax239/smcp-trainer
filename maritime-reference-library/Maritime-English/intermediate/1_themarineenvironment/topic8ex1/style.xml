<?xml version="1.0" encoding="UTF-8"?>
<style folder="res/">
	<font name="LingonetArial" source="lingonetarial.swf" />
	
	<number name="fadeInDuration">450</number>	
	<number name="fadeOutDuration">450</number>

	<number name="tipCount">3</number>	<!-- Leave undefined for unlimited tips -->
	
	<image name="bubble" x="0" y="0">bbl.png</image>
	<image name="tipButton" x="442" y="488">hint.png</image>
	<image name="hideTipButton" x="442" y="488">hint.png</image>
	<image name="tipBackground" x="34" y="90">tipbg.png</image>
	<image name="continueButton" x="608" y="446">continue.png</image>
	<boolean name="scoreDoubleOnFirstTry">true</boolean>
	<boolean name="markHintAsTry">true</boolean>
	<color name="maskColor">0x3232ff</color>
	<color name="hilightColor">0x0000ff</color>
	
	<point name="bubbleHitPoint" x="73" y="2" />

	<grid name="bubbleGrid">
		<dimensions rows="11" cols="1" />
		<position x="564" y="90" />
		<spacing x="0" y="35" />
	</grid>
	
	<textfield name="text">
		<position x="40" y="50" />
		<size w="480" h="380" />
		<format fontFamily="Arial" color="0x000000" size="14" align="left" leading="5" />
		<text></text>
	</textfield>
	
	<textfield name="bubbleText">
		<position x="0" y="10" />
		<size w="130" h="25" />
		<format fontFamily="Arial" color="0x000000" size="12" align="center" />
		<text>teksti</text>
	</textfield>
	
	<textfield name="scoreText">
		<position x="570" y="100" />
		<size w="0" h="0" />
		<format fontFamily="Arial" color="0" size="18" align="right" />
		<text></text>
	</textfield>
	
	<loader name="ui">
		<image name="background">bg.jpg</image>
		
		<textfield name="taskname">
			<position x="179" y="40" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="14" align="left" />
			<text><![CDATA[Fuel Emissions / Ex 1]]></text>
		</textfield>
		
		<textfield name="unit">
			<position x="179" y="14" />
			<size w="533" h="19" />
			<format fontFamily="Arial" color="0xFFFFFF" size="20" align="left" />
			<text><![CDATA[The Marine Environment]]></text>
		</textfield>
		
		<textpoints name="score">
			<values max="46" correct="1" error="0" min="0" correctOnFirst="2" />
			<background x="82" y="494">scorebg.png</background>
			<points>
				<position x="82" y="504" />
				<size w="67" h="39" />
				<format fontFamily="Arial" color="0x1A619F" size="16" bold="true" align="center" />
				<text><![CDATA[{points} / {maxpoints}]]></text>
			</points>

			<complete>
				<fx type="fade" from="0" to="1" duration="300" />
				<fx type="move" x="218" y="482" duration="500" delay="1500" />
				<fx type="scale" to="0.55" from="1" duration="500" delay="1500" />
				<ranges>
					<range min="-10000">
						<image x="230" y="209">done.gif</image>
					</range>
				</ranges>
			</complete>

		</textpoints>
		
		<info name="info">
			<button x="160" y="488">info.png</button>
			<background x="160" y="170">infobg.jpg</background>
			<textfield>
				<position x="17" y="36" />
				<size w="369" h="150" />
				<format fontFamily="Arial" color="0x000000" size="16" />
				<text><![CDATA[Drag and drop the words on the right in the text. For help, click "Hint". To hide, click "Hint" again.]]></text>
			</textfield>
		</info>	
	</loader>
</style>
